PORT=3001
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transport_db?schema=public

JWT_ACCESS_SECRET=replace-with-a-secure-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
TRUST_PROXY=false
CRON_TIMEZONE=America/Sao_Paulo
REMINDER_DAYS_BEFORE=3
BACKUP_DIR=./backups

SEED_ADMIN_EMAIL=admin@transport.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=System Administrator
